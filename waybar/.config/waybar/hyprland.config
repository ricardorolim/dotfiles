{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "margin-bottom": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "hyprland/workspaces"
	// "wlr/taskbar"
    ],

    "modules-center": [
    ],

    "modules-right": [
        //"tray",
        "bluetooth",
        "battery",
        "pulseaudio",
//        "custom/swww",
        "network",
        "network#2",
        "group/clocks"
    ],

    "hyprland/workspaces": {
    	"disable-scroll": false
    },

    "group/clocks": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "child-clocks",
            "transition-left-to-right": false
        },
        "modules": [
            "clock#dublin",
            "clock#recife"
        ]
    },

    "clock#dublin": {
	    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	    "format": "’ĆŚ  {:%R}",
	    "format-alt": "{:%F %T}",
	    "interval": 1
    },

    "clock#recife": {
        "timezone": "America/Recife",
	    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	    "format": "’ĆŚ  Recife: {:%R}",
	    "format-alt": "{:%F %T}",
	    "interval": 1
    },

    "tray": {
        "spacing": 10
    },

    "battery": {
	    "bat": "BAT0",
	    "interval": 120,
	    "states": {
		"warning": 15,
		"critical": 5
	    },
	    "format": "{icon}  {capacity}%",
	    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
	    "max-length": 25
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}  {volume}% ’Ŗö",
        "tooltip": false,
        "format-muted": "’Ć” Muted",
        "on-click": "pamixer -t",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’Ćź",
            "headset": "’Ćź",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        }
    },

    "bluetooth": {
	"format": "’Ŗö {status}",
	"format-connected": "’Ŗö {num_connections}",
	"tooltip-format": "{controller_alias}\t{controller_address}",
	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
	"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
	"on-click": "blueman-manager"
    },

    "network": {
	    "interface": "enp*",
	    "format": "{ifname}",
	    "format-wifi": "’ć½  {essid} ({signalStrength}%)",
	    "format-ethernet": "’āü  Wired",
	    "format-disconnected": "", //An empty format will hide the module.
	    "tooltip-format": "{ifname} via {gwaddr} ¾░ŖŚ",
	    "tooltip-format-wifi": "{essid} ({signalStrength}%) ’ć½",
	    "tooltip-format-ethernet": "{ifname} ’āü",
	    "tooltip-format-disconnected": "Disconnected",
	    "max-length": 50
    },

    "network#2": {
	    "interface": "wlan0",
	    "format": "{ifname}",
	    "format-wifi": "’ć½  {essid} ({signalStrength}%)",
	    "format-ethernet": "’āü  Wired",
	    "format-disconnected": "", //An empty format will hide the module.
	    "tooltip-format": "{ifname} via {gwaddr} ¾░ŖŚ",
	    "tooltip-format-wifi": "{essid} ({signalStrength}%) ’ć½",
	    "tooltip-format-ethernet": "{ifname} ’āü",
	    "tooltip-format-disconnected": "Disconnected",
	    "max-length": 50
    }
}
